{
  "name": "ytmusic",
  "version": "0.1.4",
  "description": "Unofficial YouTube Music Desktop Application",
  "appId": "org.mayrd.ytmusic",
  "repository": {
    "type": "git",
    "url": "git://github.com/mayrd/ytmusic-desktop.git"
  },
  "main": "main.js",
  "devDependencies": {
    "electron": "^39.2.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {},
  "build": {
    "appId": "org.mayrd.ytmusic",
    "productName": "YouTube Music",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "config/config.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "AudioVideo"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "electronDownload": {
      "mirror": "https://github.com/electron/electron/releases/download/"
    },
    "npmRebuild": false,
    "asar": true
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --win --linux --x64 --arm64",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Daniel Mayr <dg.mayr@gmail.com>"
}
